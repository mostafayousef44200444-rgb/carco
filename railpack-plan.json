{
  "name": "carco-backend",
  "install": "npm ci --omit=dev",
  "build": "npx nest build",
  "start": "node dist/main",
  "env": [
    "PORT",
    "MONGO_URI",
    "JWT_SECRET",
    "CLOUDINARY_CLOUD_NAME",
    "CLOUDINARY_API_KEY",
    "CLOUDINARY_API_SECRET"
  ],
  "cache": ["node_modules", "package-lock.json"]
}